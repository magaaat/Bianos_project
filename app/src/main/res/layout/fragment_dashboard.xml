<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboard_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header Section with Background Image Switcher -->
            <FrameLayout
                android:id="@+id/flHeader"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageSwitcher
                    android:id="@+id/isHeaderSwitcher"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay" />
            </FrameLayout>

            <!-- Search Bar and Settings Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/topBarContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/searchBarContainer"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_search_pill_glow"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivSettings"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Search product..."
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/white"
                        android:textColorHint="#CCFFFFFF"
                        android:textSize="12sp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        app:layout_constraintEnd_toStartOf="@id/ivSearchIcon"
                        app:layout_constraintStart_toStartOf="parent" />

                    <ImageView
                        android:id="@+id/ivSearchIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/ic_menu_send"
                        app:tint="#00A3FF"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_settings_glow"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Hero Text -->
            <LinearLayout
                android:id="@+id/llHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/topBarContainer">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTABLISHED 1998"
                    android:textColor="#D4A056"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biaño's\nSpecial"
                    android:textColor="@color/white"
                    android:textSize="38sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:lineSpacingExtra="-6dp"/>

                <TextView
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Authentic Italian recipes crafted with passion."
                    android:textColor="#EEEEEE"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Content Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="220dp"
                android:background="@drawable/dialog_background_rounded"
                android:backgroundTint="#F8F9FA"
                android:paddingBottom="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvOverviewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:text="Business Insights"
                    android:textColor="#1A1A1A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Revenue Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvRevenue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tvOverviewTitle">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="@drawable/bg_revenue_gradient">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvRevIconContainer"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardBackgroundColor="#33FFFFFF"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="₱"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/cvRevIconContainer"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL REVENUE"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvTodaySales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱ 0.00"
                                android:textColor="@color/white"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btnViewRevenueDetails"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/circle_background"
                            android:backgroundTint="#20FFFFFF"
                            android:src="@android:drawable/ic_menu_directions"
                            app:tint="@color/white"
                            android:padding="8dp"
                            android:scaleType="fitCenter"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats Grid -->
                <LinearLayout
                    android:id="@+id/llStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/cvRevenue">

                    <!-- Orders Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvTotalOrders"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="16dp"
                            android:orientation="vertical"
                            android:background="@drawable/bg_orders_gradient">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Orders"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvTodayOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Today"
                                android:textColor="#AAFFFFFF"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Stock Alert Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvStockAlert"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="16dp"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stock_gradient">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Low Stock Alert"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvLowStockAlerts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="All items in stock"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Tap to check notifications"
                                android:textColor="#AAFFFFFF"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Daily Report Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendDailyReport"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:text="SEND DAILY REPORT"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    app:cornerRadius="12dp"
                    app:elevation="2dp"
                    android:backgroundTint="#1A1A1A"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    app:layout_constraintTop_toBottomOf="@id/llStats" />

                <TextView
                    android:id="@+id/tvTopSellerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="20dp"
                    android:text="TOP SALES"
                    android:textColor="#555555"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnSendDailyReport" />

                <!-- Top Product Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvTopSeller"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#EEEEEE"
                    app:layout_constraintTop_toBottomOf="@id/tvTopSellerTitle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/ivTopProduct"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/bh_pizza" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTopProductName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No sales data"
                                android:textColor="#1A1A1A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvTopProductStats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:text="Start selling to see stats"
                                android:textColor="#D4A056"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
