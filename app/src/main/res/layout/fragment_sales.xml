<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- Professional Solid Black Header -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#1A1A1A"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSalesBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:fontFamily="serif"
                android:text="Sales Analytics"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSalesTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitor your business performance"
                android:textColor="#E0E0E0"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="@id/tvSalesBrand"
                app:layout_constraintTop_toBottomOf="@id/tvSalesBrand" />

            <!-- Summary Cards -->
            <LinearLayout
                android:id="@+id/llSummaryRow"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-45dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/headerBackground">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="10dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvDailyLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAILY REVENUE"
                            android:textColor="#999999"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvDailySales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="₱ 0.00"
                            android:textColor="#E67E22"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="10dp"
                    android:layout_marginStart="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MONTHLY REVENUE"
                            android:textColor="#999999"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvMonthlySales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="₱ 0.00"
                            android:textColor="#1565C0"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- RECENT ORDERS SECTION -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvRecentOrdersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEEEEE"
                app:layout_constraintTop_toBottomOf="@id/llSummaryRow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="RECENT ORDERS"
                        android:textColor="#1A1A1A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvViewAllOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="#D4A056"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Export Reports Section -->
            <TextView
                android:id="@+id/tvReportTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Export Reports"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvRecentOrdersContainer"/>

            <LinearLayout
                android:id="@+id/llReportButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvReportTitle">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportDaily"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Daily"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#D4A056"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportMonthly"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Monthly"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#D4A056"
                    android:layout_marginHorizontal="3dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportReceipt"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Receipts"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#D4A056"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Analytics Charts Section -->
            <TextView
                android:id="@+id/tvVisualTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Analytics Charts"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llReportButtons"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvBarChart"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEEEEE"
                app:layout_constraintTop_toBottomOf="@id/tvVisualTitle">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Revenue Trend"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp"/>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChartDaily"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvLineChart"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEEEEE"
                app:layout_constraintTop_toBottomOf="@id/cvBarChart">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Revenue Trend"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp"/>
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChartMonthly"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvPieChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEEEEE"
                app:layout_constraintTop_toBottomOf="@id/cvLineChart">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Top Selling Products"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="12dp"/>
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChartBestSellers"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
