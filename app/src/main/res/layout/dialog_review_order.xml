<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="#121212"
    app:strokeWidth="1.5dp"
    app:strokeColor="#2A2A2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvReviewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REVIEW ORDER"
            android:textColor="#D4A056"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <TextView
            android:id="@+id/tvReviewCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Customer Name"
            android:textColor="#D4A056"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <View
            android:layout_width="40dp"
            android:layout_height="3.5dp"
            android:layout_marginTop="16dp"
            android:background="#D4A056" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="ORDER SUMMARY"
            android:textColor="#999999"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:fadeScrollbars="false">
            <TextView
                android:id="@+id/tvReviewOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items list..."
                android:textColor="#DDDDDD"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp" />
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#2A2A2A" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Amount"
                android:textColor="#999999"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvReviewTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱ 0.00"
                android:textColor="#D4A056"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReviewEdit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="0.8"
                android:layout_marginEnd="8dp"
                android:text="EDIT"
                android:textColor="#D4A056"
                app:strokeColor="#D4A056"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReviewConfirm"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.2"
                android:layout_marginStart="8dp"
                android:text="PLACE ORDER"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="#D4A056"
                app:cornerRadius="16dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
