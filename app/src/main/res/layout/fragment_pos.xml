<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp">

            <!-- Professional Solid Black Header -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#1A1A1A"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPosBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:fontFamily="serif"
                android:text="Biaño's"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPosTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Pizza Experience"
                android:textColor="#E0E0E0"
                android:textSize="15sp"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="@id/tvPosBrand"
                app:layout_constraintTop_toBottomOf="@id/tvPosBrand" />

            <!-- Clean Underlined Tab Selector -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/catCardContainer"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="-27dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/headerBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layoutPizza"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:id="@+id/btnCatPizza"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PIZZA"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A"
                            android:letterSpacing="0.1"/>
                        <View
                            android:id="@+id/indicatorPizza"
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="4dp"
                            android:background="#D4A056"
                            android:visibility="visible"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDrinks"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:id="@+id/btnCatDrinks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DRINKS"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.1"/>
                        <View
                            android:id="@+id/indicatorDrinks"
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="4dp"
                            android:background="#D4A056"
                            android:visibility="gone"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Product List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/catCardContainer"
                tools:listitem="@layout/item_product" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Professional Bottom Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cartSectionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#333333">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvCartItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 items"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱ 0.00"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmOrder"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:paddingHorizontal="24dp"
                android:text="CHECKOUT"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#D4A056"
                app:cornerRadius="14dp"
                app:elevation="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
