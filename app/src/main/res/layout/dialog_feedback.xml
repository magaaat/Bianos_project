<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <FrameLayout
            android:id="@+id/flIconContainer"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_circle_success">

            <ImageView
                android:id="@+id/ivFeedbackIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_radio_selected"
                app:tint="#4ADE80" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvFeedbackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order Placed!"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvFeedbackMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your order has been saved successfully."
            android:textColor="#666666"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="32dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFeedbackAction"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/glass_pill_bg"
            android:backgroundTint="#DCFCE7"
            android:text="Dismiss"
            android:textAllCaps="false"
            android:textColor="#166534"
            android:textSize="17sp"
            android:textStyle="bold"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>