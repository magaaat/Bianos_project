<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background_rounded_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STOCK IN"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvManageItemName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Name"
                        android:textColor="#D4A056"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnManageCancelIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close_thin"
                    app:tint="#888888" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvCurrentStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Current: 10 units"
                android:textColor="#888888"
                android:textSize="12sp" />

            <!-- Transaction Type Selection (Hidden by default, used in code) -->
            <TextView
                android:id="@+id/tvTransactionTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Transaction Type"
                android:textColor="#888888"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeIn"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="IN" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeWithdraw"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="OUT" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeSpoilage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SPOIL" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="Quantity"
                android:textColorHint="#666666"
                app:boxBackgroundColor="#1A1A1A"
                app:boxStrokeColor="#D4A056"
                app:hintTextColor="#D4A056">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etManageQty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Remarks"
                android:textColorHint="#666666"
                app:boxBackgroundColor="#1A1A1A"
                app:boxStrokeColor="#D4A056"
                app:hintTextColor="#D4A056">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etManageReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <CheckBox
                android:id="@+id/cbConvertToRegular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Convert to Regular Dough"
                android:textColor="@color/white"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageCancel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:text="CANCEL"
                    android:textColor="#888888" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageSave"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.5"
                    android:text="SUBMIT"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="#D4A056"
                    app:cornerRadius="14dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
