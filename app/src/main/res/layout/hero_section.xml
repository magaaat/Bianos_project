<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Hero Image - Full Screen -->
    <ImageView
        android:id="@+id/ivHeroBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@mipmap/loadingscreen"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Gradient Overlay - Transitions from Transparent to Soft White/Orange -->
    <View
        android:id="@+id/vGradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/hero_gradient_overlay"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Content Section - Floating near the bottom -->
    <LinearLayout
        android:id="@+id/llHeroContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvHeroWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to"
            android:textColor="#000000"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeroBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biaño's Pizza"
            android:textColor="#FF6A00"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeroTagline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Experience the perfect stretch of cheese\nin every bite. Freshly baked, just for you."
            android:textColor="#333333"
            android:textSize="18sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
