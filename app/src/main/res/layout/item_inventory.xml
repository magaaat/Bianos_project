<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginHorizontal="16dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:id="@+id/llInventoryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <!-- Item Info Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mozzarella Cheese"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.01"/>

            <TextView
                android:id="@+id/tvItemUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="20 slices per block"
                android:textColor="#7F8C8D"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Dynamic Stock Visualization -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStockCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45.0"
                android:textColor="#2C3E50"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9">
                <TextView
                    android:id="@+id/tvStockStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IN STOCK"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textColor="#2E7D32"
                    android:letterSpacing="0.05"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnQuickAdd"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_add"
                android:background="@drawable/glass_circle_bg"
                android:backgroundTint="#FFF8E1"
                app:tint="#D4A056"
                android:padding="9dp"
                android:scaleType="fitCenter"
                android:contentDescription="Restock" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/trash"
                android:background="@drawable/glass_circle_bg"
                android:backgroundTint="#FFEBEE"
                app:tint="#E74C3C"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Remove" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
