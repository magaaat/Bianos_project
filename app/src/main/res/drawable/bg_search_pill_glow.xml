<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The outer glow (blue/cyan on the left) - subtle and transparent -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#4D00A3FF"
                android:centerColor="#00000000"
                android:endColor="#00000000"
                android:angle="0" />
        </shape>
    </item>

    <!-- The inner dark pill - Glassmorphism effect (High Transparency) -->
    <item android:left="1dp" android:top="0.5dp" android:right="0.5dp" android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#260F111E" />
            <stroke android:width="1dp" android:color="#33FFFFFF"/>
        </shape>
    </item>
</layer-list>
